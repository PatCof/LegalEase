{
  "version": 2,
    "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/backend/gemini_ai.ts"
    },
    {
      "source": "/(.*)",
      "destination": "/LegalEase/$1"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/"
    }
  ],
  "buildCommand": "npm install --prefix backend && npm install --prefix LegalEase && npm run build --prefix LegalEase",
  "outputDirectory": "LegalEase/dist"
}