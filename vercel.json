{
  "version": 2,
  "builds": [
    {
      "src": "backend/gemini_ai.ts",
      "use": "@vercel/node"
    },
     {
        "src": "LegalEase/package.json",
        "use": "@vercel/static-build",
        "config": { "distDir": "dist" }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/"
    }
  ],
  "buildCommand": "npm install --prefix backend && npm install --prefix LegalEase && npm run build --prefix LegalEase",
  "outputDirectory": "LegalEase/dist"
}